PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/multi-shop
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:4000

# ── Firebase Cloud Messaging (Push Notifications) ──────────────────────────────
# Get these from Firebase Console → Project Settings → Service Accounts
# → Generate new private key → copy values from the downloaded JSON
FCM_PROJECT_ID=your-firebase-project-id
FCM_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Paste the full private key — keep the \n literals, they are converted at runtime
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvAIBADANBgkqhkiG...\n-----END PRIVATE KEY-----\n"
